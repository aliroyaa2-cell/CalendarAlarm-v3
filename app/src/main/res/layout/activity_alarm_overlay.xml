<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/alarm_overlay_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Live clock -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="28dp">

            <TextView
                android:id="@+id/tvClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/alarm_overlay_text"
                android:textSize="48sp"
                android:textStyle="normal"
                android:fontFamily="sans-serif-light"
                android:text="00:00:00" />

            <TextView
                android:id="@+id/tvClockAmpm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/alarm_overlay_text_secondary"
                android:textSize="20sp"
                android:text="ص" />

        </LinearLayout>

        <!-- Source label -->
        <TextView
            android:id="@+id/tvSourceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textColor="@color/alarm_overlay_accent"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"
            android:text="" />

        <!-- Big title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/alarm_overlay_text"
            android:textSize="30sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="10dp"
            android:text="" />

        <!-- Event time -->
        <TextView
            android:id="@+id/tvEventTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/alarm_overlay_text_secondary"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:text="" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/alarm_overlay_text"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:text="" />

        <!-- Location -->
        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/alarm_overlay_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="32dp"
            android:visibility="gone"
            android:text="" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="20dp" />

        <!-- Snooze grid 2x2 — Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze5"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:textColor="@color/alarm_overlay_text"
                android:textSize="15sp"
                app:strokeColor="@color/alarm_overlay_text"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                android:text="@string/alarm_snooze_5" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze10"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginStart="6dp"
                android:textColor="@color/alarm_overlay_text"
                android:textSize="15sp"
                app:strokeColor="@color/alarm_overlay_text"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                android:text="@string/alarm_snooze_10" />

        </LinearLayout>

        <!-- Snooze grid 2x2 — Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze30"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:textColor="@color/alarm_overlay_text"
                android:textSize="15sp"
                app:strokeColor="@color/alarm_overlay_text"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                android:text="@string/alarm_snooze_30" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnoozeMore"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginStart="6dp"
                android:textColor="@color/alarm_overlay_text"
                android:textSize="15sp"
                app:strokeColor="@color/alarm_overlay_text"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                android:text="@string/alarm_snooze_more" />

        </LinearLayout>

        <!-- Open event - full width -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="10dp"
            android:textColor="@color/alarm_overlay_text"
            android:textSize="16sp"
            app:strokeColor="@color/alarm_overlay_text"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            android:text="@string/alarm_action_edit" />

        <!-- Dismiss - full width red -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDismiss"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/alarm_overlay_dismiss_bg"
            app:cornerRadius="10dp"
            android:text="@string/alarm_action_dismiss" />

    </LinearLayout>

</ScrollView>
