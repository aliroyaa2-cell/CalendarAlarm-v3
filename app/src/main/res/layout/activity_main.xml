<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ━━━━━━━━━━ Top bar: Samsung search + menu ━━━━━━━━━━ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearchSamsung"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:textColor="#64B5F6"
            android:textSize="14sp"
            app:strokeColor="#64B5F6"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            app:icon="@android:drawable/ic_menu_search"
            app:iconTint="#64B5F6"
            app:iconGravity="textStart"
            android:text="@string/btn_search_samsung" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_more"
            android:tint="#BDBDBD"
            android:contentDescription="@string/btn_menu_desc" />

    </LinearLayout>

    <!-- ━━━━━━━━━━ Tabs: Upcoming / Past ━━━━━━━━━━ -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1F1F1F"
        app:tabIndicatorColor="#64B5F6"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabTextColor="#BDBDBD"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_upcoming" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_past" />

    </com.google.android.material.tabs.TabLayout>

    <!-- ━━━━━━━━━━ Search bar ━━━━━━━━━━ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="14dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#1F1F1F"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayout">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:queryHint="@string/search_hint"
            android:iconifiedByDefault="false"
            app:queryBackground="@android:color/transparent"
            app:searchHintIcon="@android:drawable/ic_menu_search" />

    </androidx.cardview.widget.CardView>

    <!-- ━━━━━━━━━━ Permissions banner ━━━━━━━━━━ -->
    <LinearLayout
        android:id="@+id/bannerPermissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/banner_warning_bg"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        tools:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/banner_warning_text"
            android:textStyle="bold"
            android:textSize="15sp"
            android:text="@string/permissions_banner_title" />

        <TextView
            android:id="@+id/tvBannerSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/banner_warning_text"
            android:textSize="13sp"
            android:text="@string/permissions_banner_subtitle" />

    </LinearLayout>

    <!-- ━━━━━━━━━━ Events list ━━━━━━━━━━ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/bannerPermissions"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ━━━━━━━━━━ Empty state ━━━━━━━━━━ -->
    <LinearLayout
        android:id="@+id/emptyView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="@string/empty_events" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="#BDBDBD"
            android:textSize="14sp"
            android:text="@string/empty_events_hint" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
