<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ━━━━━━━━━━ Permissions ━━━━━━━━━━ -->

    <!-- Calendar -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Full Screen Intent (Android 14+) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Exact Alarms -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Boot completion -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Wake lock for alarm screen -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibration -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Disable keyguard so alarm screen shows over lock -->
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD" />

    <!-- Audio access for ringtone picker (Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Battery optimization exemption -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
        tools:ignore="BatteryLife" />

    <!-- Show on top (for alarm activity) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"
        tools:ignore="ProtectedPermissions" />

    <!-- ━━━━━━━━━━ Package Visibility (Android 11+) ━━━━━━━━━━ -->
    <!-- Required to discover calendar apps that can open event URIs -->
    <queries>
        <!-- Calendar event URIs (Google Calendar, Samsung Calendar, etc.) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="content" android:host="com.android.calendar" />
        </intent>
        <!-- Generic calendar event view -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="vnd.android.cursor.item/event" />
        </intent>
        <!-- Direct package mention (most calendar apps) -->
        <package android:name="com.google.android.calendar" />
        <package android:name="com.samsung.android.calendar" />
        <package android:name="com.microsoft.office.outlook" />
    </queries>

    <application
        android:name=".CalendarAlarmApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CalendarAlarm"
        tools:targetApi="35">

        <!-- ━━━━━━━━━━ Activities ━━━━━━━━━━ -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SourceCalendarsActivity"
            android:exported="false"
            android:label="@string/title_source_calendars"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/title_settings"
            android:parentActivityName=".MainActivity" />

        <!-- AlarmOverlayActivity: shown over lock screen -->
        <activity
            android:name=".AlarmOverlayActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:showOnLockScreen="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:taskAffinity=""
            android:theme="@style/Theme.CalendarAlarm.Fullscreen" />

        <!-- ━━━━━━━━━━ Services ━━━━━━━━━━ -->

        <service
            android:name=".service.CalendarSyncService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ━━━━━━━━━━ Receivers ━━━━━━━━━━ -->

        <!-- Alarm trigger -->
        <receiver
            android:name=".alarm.EventAlarmReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Boot receiver: reschedule alarms after restart -->
        <receiver
            android:name=".alarm.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
